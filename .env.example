# Supabase Configuration (Get these from your Supabase Project Settings > API)
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Gemini API Key (Get this from https://aistudio.google.com)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Note: For GitHub Pages deployment, add these as "Repository Secrets" in your GitHub Repository Settings.
